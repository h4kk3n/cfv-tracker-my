{
  "rules": {
    "chats": {
      "$chatId": {
        ".read": "auth != null && root.child('chats/' + $chatId + '/participants/' + auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || root.child('chats/' + $chatId + '/participants/' + auth.uid).exists())",
        "messages": {
          "$msgId": {
            ".validate": "newData.child('senderId').val() === auth.uid"
          }
        },
        "typing": {
          "$userId": {
            ".validate": "$userId === auth.uid"
          }
        }
      }
    },
    "userChats": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        "$chatId": {
          ".write": "auth != null"
        }
      }
    },
    "presence": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $userId"
      }
    }
  }
}
